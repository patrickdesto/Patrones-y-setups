//@version=6
strategy("Estrategia Reversión: Gatillo Quirúrgico V3", overlay=true, initial_capital=1000)

// --- 1. SMAs MATE OSCURAS (LÍNEAS FINAS) ---
// Cambiamos linewidth a 1 para que sean más estéticas
sma20  = ta.sma(close, 20)
sma50  = ta.sma(close, 50)
sma100 = ta.sma(close, 100)
sma200 = ta.sma(close, 200)
rsiVal = ta.rsi(close, 14)

// --- 2. FILTROS DE TENDENCIA INSTITUCIONAL ---
tendenciaCorrecta = sma100 < sma200 
precioBajoMedias  = close < sma100 and close < sma200

// --- 3. AVISO DE PISO EXTREMO (VISUAL SOLAMENTE) ---
tocoPisoExtremo = rsiVal < 26
plotshape(tocoPisoExtremo, style=shape.diamond, location=location.belowbar, color=color.new(#00ced1, 0), size=size.tiny, title="Aviso < 26")

// --- 4. GATILLO QUIRÚRGICO (MONTAJE SMA 20 + RSI 40-60) ---
rsiEnZona = rsiVal >= 40 and rsiVal <= 60
// ta.crossover detecta el momento exacto en que el cuerpo cruza la media
cuerpoCruzaSma = ta.crossover(math.min(open, close), sma20)

triggerEntrada = tendenciaCorrecta and precioBajoMedias and rsiEnZona and cuerpoCruzaSma

// --- 5. SEÑALES VISUALES Y EJECUCIÓN ---
if triggerEntrada
    strategy.entry("Long", strategy.long)
    label.new(bar_index, low, text="ENTRADA", style=label.style_label_up, color=color.new(color.green, 20), textcolor=color.white, yloc=yloc.belowbar)

plotshape(triggerEntrada, style=shape.triangleup, location=location.belowbar, color=color.green, size=size.normal)

// --- 6. LÓGICA DE COLOR (AVISO NARANJA) ---
avisoNaranja = tendenciaCorrecta and precioBajoMedias and rsiEnZona and math.max(open, close) < sma20
barcolor(triggerEntrada ? color.green : (avisoNaranja ? color.orange : na))

// --- 7. DIBUJO DE SMAs MATE (LINEWIDTH=1) ---
plot(sma20,  color=color.new(#00332a, 10), title="SMA 20",  linewidth=1)
plot(sma50,  color=color.new(#fbc02d, 10), title="SMA 50",  linewidth=1)
plot(sma100, color=color.new(#e65100, 10), title="SMA 100", linewidth=1)
plot(sma200, color=color.new(#801922, 10), title="SMA 200", linewidth=1)
