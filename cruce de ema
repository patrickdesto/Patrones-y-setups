# 1. Crear carpeta principal
New-Item -Path "patrones-setup" -ItemType Directory
cd "patrones-setup"

# 2. Definir los nombres de tus 3 patrones
$nombres = @(
    "cruce-de-ema",
    "reversion-sobreextension-ema20",
    "soportes-y-velas-reversion"
)

# 3. Crear subcarpetas para cada uno
foreach ($n in $nombres) {
    mkdir "$n/codigo", "$n/imagenes", "$n/backtesting", "$n/documentacion"
    # Crear archivos base vacíos para que no se pierdan las carpetas
    New-Item -Path "$n/README.md" -ItemType File
    New-Item -Path "$n/codigo/script_v1.pine" -ItemType File
}

# 4. Crear el índice principal
New-Item -Path "README.md" -ItemType File

Write-Host "🚀 Estructura de 'patrones-setup' lista para usar.
